# Exclude tooling from the published package so pub does not validate
# tool/catalog_app (which has its own pubspec and package name) as part of the root package.
# CI and local development still use tool/ from the repo.
tool/

# Exclude Cursor/IDE metadata (may be checked in but must not ship to pub.dev).
.cursor/
.claude/
.opencode/
.specify/
.agent/
.agents/
_agent/
_agents/
brain/
knowledge/
.gemini/

# Exclude GitHub Pages docs (use doc/ for pub.dev conventions).
docs/

# Exclude build artifacts — these are regenerated and must not ship to pub.dev.
build/
coverage/
