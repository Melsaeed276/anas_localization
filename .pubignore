# Exclude tooling from the published package so pub does not validate
# tool/catalog_app (which has its own pubspec and package name) as part of the root package.
# CI and local development still use tool/ from the repo.
tool/

# Exclude Cursor/IDE metadata (may be checked in but must not ship to pub.dev).
.cursor/
.claude/
.opencode/
.specify/
.agent/
.agents/
_agent/
_agents/
brain/
knowledge/
.gemini/

# Exclude GitHub Pages docs (use doc/ for pub.dev conventions).
docs/

# Exclude build artifacts — these are regenerated and must not ship to pub.dev.
build/
coverage/

# Exclude CI-generated API docs (dart doc output) — too large and not needed on pub.dev.
doc/api/

# Exclude internal/agent markdown files not intended for pub.dev consumers.
AGENTS.md
CLAUDE.md
COMPETITOR_LOCALIZATION_LANDSCAPE.md
PACKAGE_IMPROVEMENT_SUGGESTIONS.md
CHANGE_REPORT.md
RUNTIME_LOOKUP_SUPPORT.md
TRADEMARK.md

# Exclude debug logs.
firebase-debug.log
*.log

# Exclude built MkDocs site (generated, not needed by consumers).
site/

# Exclude specs/planning docs (internal development artefacts).
specs/
